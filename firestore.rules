rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // As this app relies on PINs (document IDs) rather than Firebase Auth,
    // we use schema validation to prevent structural poisoning, though reads are allowed.
    
    function isValidBrand(brand) {
       return brand is map && brand.size() <= 200
         && (!brand.keys().hasAny(['brandName']) || brand.get('brandName', '') is string)
         && (!brand.keys().hasAny(['logoUrl']) || brand.get('logoUrl', '') is string)
         && (!brand.keys().hasAny(['primaryColor']) || brand.get('primaryColor', '') is string)
         && (!brand.keys().hasAny(['secondaryColor']) || brand.get('secondaryColor', '') is string);
    }

    function isValidStoreConfig(data) {
      return data is map && data.size() >= 0 && data.size() <= 50
        && (!data.keys().hasAny(['adminPin']) || data.get('adminPin', '') is string)
        && (!data.keys().hasAny(['brand']) || isValidBrand(data.brand));
    }
    
    function isValidBooking(data) {
      return data.size() >= 0 && data.size() <= 15
        && data.get('id', '') is string && data.get('id', '').size() <= 64
        && data.get('service', '') is string && data.get('service', '').size() <= 200
        && data.get('date', '') is string && data.get('date', '').size() <= 50
        && data.get('time', '') is string && data.get('time', '').size() <= 50
        && data.get('clientName', '') is string && data.get('clientName', '').size() <= 100
        && data.get('clientPhone', '') is string && data.get('clientPhone', '').size() <= 50
        && data.get('status', 'pending') in ["pending", "confirmed", "cancelled"]
        && data.get('createdAt', '') is string && data.get('createdAt', '').size() <= 50
        && data.get('updatedAt', '') is string && data.get('updatedAt', '').size() <= 50;
    }

    // Stores collection: Private configurations
    // PIN acts as the document ID and the security key for the business.
    match /stores/{pin} {
      allow list: if true; 
      allow get: if isValidId(pin); 
      allow create: if isValidId(pin) && isValidStoreConfig(incoming());
      allow update: if isValidId(pin) && isValidStoreConfig(incoming());
      allow delete: if isValidId(pin); 

      // Support subcollection mappings
      match /bookings/{bookingId} {
        allow list, get: if isValidId(pin) && isValidId(bookingId);
        allow create: if isValidId(pin) && isValidId(bookingId) && isValidBooking(incoming());
        allow update: if isValidId(pin) && isValidId(bookingId) && isValidBooking(incoming());
        allow delete: if isValidId(pin) && isValidId(bookingId);
      }
    }

    // Public collection: The published landing page
    match /public/{docId} {
      allow get, list: if true;
      allow create: if (docId == 'main_config' || docId == 'connectivity_test') && isValidStoreConfig(incoming());
      allow update: if (docId == 'main_config' || docId == 'connectivity_test') && isValidStoreConfig(incoming());
    }
  }
}
